<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Page Not Found</title>
  <link rel="stylesheet" href="/css/output.css" />
  <link rel="stylesheet" href="/css/polish.css"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body class="bg-slate-50 text-slate-800" style="overflow-x:hidden">

  <%- include('partials/navbar', { page: '', isAdmin: typeof isAdmin !== 'undefined' ? isAdmin : false }) %>

  <section style="min-height:60vh;display:flex;align-items:center;justify-content:center;padding:48px 24px">
    <div class="anim-fade-up" style="text-align:center;max-width:480px">
      <div style="width:72px;height:72px;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:20px;display:flex;align-items:center;justify-content:center;margin:0 auto 24px">
        <i class="fa-solid fa-compass" style="color:#059669;font-size:28px"></i>
      </div>
      <p style="font-size:11px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:#059669;margin:0 0 10px">Error 404</p>
      <h1 style="font-size:26px;font-weight:800;color:#0f172a;margin:0 0 12px">Page not found</h1>
      <p style="font-size:14px;line-height:1.8;color:#64748b;margin:0 0 28px">
        The page you're looking for doesn't exist, may have been moved, or the link might be mistyped.
      </p>
      <a href="/" style="display:inline-flex;align-items:center;gap:8px;background:#059669;color:#fff;border-radius:12px;padding:12px 24px;font-size:14px;font-weight:600;text-decoration:none">
        <i class="fa-solid fa-house"></i> Back to homepage
      </a>
    </div>
  </section>

  <%- include('partials/footer') %>
  <script src="/js/animations.js" defer></script>
</body>
</html>
