<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title><%= title %></title>
<link rel="stylesheet" href="/css/output.css"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<style>
  *{box-sizing:border-box}
  html,body{height:100%;margin:0;padding:0;overflow:hidden}
  @media(max-width:768px){html,body{overflow:auto}}
  @keyframes fadeInUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
  @keyframes fadeInLeft{from{opacity:0;transform:translateX(-20px)}to{opacity:1;transform:translateX(0)}}
  @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
  @keyframes pulse{0%,100%{opacity:.6}50%{opacity:1}}
  @keyframes shimmer{0%{background-position:-200% 0}100%{background-position:200% 0}}
  .wrap{display:flex;height:100vh}
  .left{display:none;flex-direction:column;justify-content:space-between;width:50%;padding:48px;background:linear-gradient(160deg,#022c22 0%,#064e3b 45%,#065f46 100%);position:relative;overflow:hidden}
  @media(min-width:1024px){.left{display:flex}}
  .left-blob1{position:absolute;top:-60px;right:-60px;width:220px;height:220px;border-radius:50%;background:rgba(16,185,129,.15);filter:blur(40px);animation:float 6s ease-in-out infinite}
  .left-blob2{position:absolute;bottom:-40px;left:-40px;width:180px;height:180px;border-radius:50%;background:rgba(6,182,212,.1);filter:blur(40px);animation:float 8s ease-in-out infinite reverse}
  .left-content{position:relative;z-index:1;animation:fadeInLeft .6s ease forwards}
  .feat{display:flex;align-items:flex-start;gap:14px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:14px;padding:16px;margin-bottom:10px;transition:background .2s,border-color .2s}
  .feat:hover{background:rgba(255,255,255,.09);border-color:rgba(255,255,255,.2)}
  .feat-icon{width:36px;height:36px;border-radius:10px;background:rgba(16,185,129,.25);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:transform .2s}
  .feat:hover .feat-icon{transform:scale(1.1)}
  .right{flex:1;display:flex;align-items:center;justify-content:center;padding:32px 24px;background:#f8fafc;overflow-y:auto}
  .form-card{width:100%;max-width:380px;animation:fadeInUp .5s ease forwards}
  .input-wrap{position:relative}
  .icon-l{position:absolute;left:13px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:13px;pointer-events:none;transition:color .2s}
  .field-input{width:100%;padding:11px 40px 11px 38px;border:1.5px solid #e2e8f0;border-radius:11px;font-size:14px;outline:none;background:#fff;color:#0f172a;transition:border-color .2s,box-shadow .2s}
  .field-input:focus{border-color:#059669;box-shadow:0 0 0 3px rgba(5,150,105,.12)}
  .field-input:focus+.icon-l,.input-wrap:focus-within .icon-l{color:#059669}
  .toggle-pw{position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:#94a3b8;font-size:13px;padding:4px;transition:color .2s}
  .toggle-pw:hover{color:#059669}
  .submit-btn{width:100%;padding:12px;background:linear-gradient(135deg,#059669,#047857);color:#fff;border:none;border-radius:11px;font-size:14px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:transform .2s,box-shadow .2s,opacity .2s;position:relative;overflow:hidden}
  .submit-btn::before{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(255,255,255,.15),transparent);background-size:200% 100%;animation:shimmer 2.5s infinite}
  .submit-btn:hover{transform:translateY(-2px);box-shadow:0 8px 20px rgba(5,150,105,.35)}
  .submit-btn:active{transform:translateY(0)}
  .error-box{display:flex;align-items:center;gap:10px;background:#fef2f2;border:1px solid #fecaca;border-radius:10px;padding:12px 14px;margin-bottom:20px;animation:fadeInUp .3s ease}
  .back-link{display:inline-flex;align-items:center;gap:6px;font-size:13px;color:#64748b;text-decoration:none;transition:color .2s;padding:4px 0}
  .back-link:hover{color:#059669}
  #mobileLogo{display:none}
  @media(max-width:1023px){
    .wrap{height:auto;flex-direction:column}
    .left{display:none!important}
    .right{padding:40px 20px;min-height:100vh;width:100%;flex:none}
    .form-card{max-width:420px}
    html,body{overflow:auto;height:auto}
    #mobileLogo{display:flex!important}
  }
</style>
</head>
<body style="overflow-x:hidden">
<div class="wrap">

  <!-- Left branding panel -->
  <div class="left">
    <div class="left-blob1"></div>
    <div class="left-blob2"></div>

    <div class="left-content">
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:48px">
        <div style="width:44px;height:44px;background:linear-gradient(135deg,#10b981,#059669);border-radius:13px;display:flex;align-items:center;justify-content:center;font-size:19px;font-weight:800;color:#fff;box-shadow:0 4px 12px rgba(5,150,105,.4)">N</div>
        <div>
          <p style="font-size:10px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:#6ee7b7;margin:0">NutriDetect</p>
          <p style="font-size:13px;font-weight:700;color:#fff;margin:0">Deficiency Detection System</p>
        </div>
      </div>

      <div>
        <h2 style="font-size:28px;font-weight:900;line-height:1.25;color:#fff;margin:0 0 14px">Nutritional Deficiency Detection System</h2>
        <p style="font-size:13px;line-height:1.8;color:#a7f3d0;margin:0 0 28px">Administrative access for viewing assessments, managing records, and monitoring nutrient analysis results.</p>

        <div class="feat"><div class="feat-icon"><i class="fa-solid fa-chart-bar" style="color:#6ee7b7;font-size:13px"></i></div><div><p style="font-size:13px;font-weight:600;color:#fff;margin:0 0 3px">Assessment Dashboard</p><p style="font-size:11px;color:#a7f3d0;margin:0;line-height:1.5">View all saved assessments, scores, and nutrient findings.</p></div></div>
        <div class="feat"><div class="feat-icon"><i class="fa-solid fa-clock-rotate-left" style="color:#6ee7b7;font-size:13px"></i></div><div><p style="font-size:13px;font-weight:600;color:#fff;margin:0 0 3px">Assessment History</p><p style="font-size:11px;color:#a7f3d0;margin:0;line-height:1.5">Browse records, download PDF reports, and manage entries.</p></div></div>
        <div class="feat"><div class="feat-icon"><i class="fa-solid fa-shield-halved" style="color:#6ee7b7;font-size:13px"></i></div><div><p style="font-size:13px;font-weight:600;color:#fff;margin:0 0 3px">Secure Access</p><p style="font-size:11px;color:#a7f3d0;margin:0;line-height:1.5">Session-protected panel. Restricted to authorized use only.</p></div></div>
      </div>
    </div>

    <p style="position:relative;z-index:1;font-size:11px;color:#6ee7b7;margin:0">Nutritional Deficiency Detection System · Administrative Panel</p>
  </div>

  <!-- Right login form -->
  <div class="right">
    <div class="form-card">

      <!-- Mobile logo — shown only on mobile (left panel hidden) -->
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:32px" id="mobileLogo">
        <div style="width:40px;height:40px;background:#059669;border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:17px;font-weight:800;color:#fff">N</div>
        <div>
          <p style="font-size:10px;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:#0d9488;margin:0">NutriDetect</p>
          <p style="font-size:13px;font-weight:700;color:#0f172a;margin:0">Deficiency Detection System</p>
        </div>
      </div>

      <div style="margin-bottom:24px">
        <h1 style="font-size:22px;font-weight:800;color:#0f172a;margin:0 0 7px">Admin login</h1>
        <p style="font-size:13px;color:#64748b;margin:0">Enter your password to access the dashboard.</p>
      </div>

      <% if (errorMessage) { %>
      <div class="error-box">
        <i class="fa-solid fa-circle-exclamation" style="color:#ef4444;font-size:14px;flex-shrink:0"></i>
        <p style="font-size:13px;font-weight:500;color:#991b1b;margin:0"><%= errorMessage %></p>
      </div>
      <% } %>

      <form action="/admin/login" method="POST">
        <div style="margin-bottom:18px">
          <label for="password" style="display:block;font-size:12px;font-weight:600;color:#374151;margin-bottom:6px">Admin password</label>
          <div class="input-wrap">
            <i class="fa-solid fa-lock icon-l"></i>
            <input id="password" class="field-input" type="password" name="password" placeholder="Enter admin password" autocomplete="current-password" required>
            <button type="button" class="toggle-pw" id="toggleBtn" tabindex="-1">
              <i class="fa-solid fa-eye" id="toggleIcon"></i>
            </button>
          </div>
        </div>

        <button type="submit" class="submit-btn">
          <i class="fa-solid fa-right-to-bracket" style="font-size:13px"></i>
          Sign in to dashboard
        </button>
      </form>

      <div style="margin-top:24px;padding-top:20px;border-top:1px solid #e2e8f0">
        <a href="/" class="back-link">
          <i class="fa-solid fa-arrow-left" style="font-size:11px"></i> Back to assessment
        </a>
      </div>
      <p style="font-size:11px;color:#94a3b8;margin-top:12px">Authorized administrative access only.</p>
    </div>
  </div>
</div>

<script>
// Mobile logo visibility handled by CSS
// Password toggle
document.getElementById('toggleBtn').addEventListener('click', function(){
  const inp = document.getElementById('password');
  const ico = document.getElementById('toggleIcon');
  inp.type = inp.type === 'password' ? 'text' : 'password';
  ico.className = inp.type === 'password' ? 'fa-solid fa-eye' : 'fa-solid fa-eye-slash';
});
// Subtle form appear animation
document.querySelector('.form-card').style.opacity = '0';
setTimeout(() => { document.querySelector('.form-card').style.opacity = '1'; }, 50);
</script>
</body>
</html>
