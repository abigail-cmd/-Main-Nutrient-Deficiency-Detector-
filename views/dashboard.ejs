<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Admin Dashboard</title>
<link rel="stylesheet" href="/css/output.css" />
<link rel="stylesheet" href="/css/polish.css"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="bg-slate-50 text-slate-800">

<%- include('partials/navbar', { page: 'dashboard', isAdmin: true }) %>

<section class="bg-gradient-to-br from-emerald-900 via-teal-800 to-slate-900 text-white">
<div class="mx-auto max-w-7xl px-6 py-14">
  <div class="grid gap-8 md:grid-cols-[1.4fr_0.9fr] md:items-center">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-100">Overview & Analytics</p>
      <h2 class="mt-4 text-4xl font-black md:text-5xl">Assessment dashboard for stored nutrition reports.</h2>
      <p class="mt-5 max-w-3xl text-base leading-8 text-slate-200">
        This dashboard provides a quick overview of submitted assessments, risk distribution, average BMI, and focus nutrient insights across saved records.
      </p>

      <div class="mt-8 flex flex-wrap gap-4">
        <a href="#summary" class="rounded-2xl bg-emerald-500 px-6 py-3 font-semibold text-white transition hover:bg-emerald-400">
          View Summary
        </a>
        <a href="#charts" class="rounded-2xl border border-white/20 bg-white/10 px-6 py-3 font-semibold text-white transition hover:bg-white/20">
          View Charts
        </a>
      </div>
    </div>

    <div class="rounded-[2rem] border border-white/10 bg-white/10 p-5 backdrop-blur-md">
      <div class="rounded-[1.5rem] bg-white p-6 text-slate-800 shadow-xl">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-teal-700">Dashboard Snapshot</p>
        <div class="mt-5 grid gap-4 sm:grid-cols-2">
          <div class="rounded-2xl bg-slate-50 p-4">
            <p class="text-sm text-slate-500">Stored Assessments</p>
            <p id="snapshotTotalAssessments" class="mt-1 text-2xl font-bold text-slate-900">0</p>
          </div>
          <div class="rounded-2xl bg-slate-50 p-4">
            <p class="text-sm text-slate-500">Average BMI</p>
            <p id="snapshotAverageBmi" class="mt-1 text-2xl font-bold text-slate-900">0</p>
          </div>
          <div class="rounded-2xl bg-slate-50 p-4">
            <p class="text-sm text-slate-500">High Risk Cases</p>
            <p id="snapshotHighRisk" class="mt-1 text-2xl font-bold text-slate-900">0</p>
          </div>
          <div class="rounded-2xl bg-slate-50 p-4">
            <p class="text-sm text-slate-500">Low Risk Cases</p>
            <p id="snapshotLowRisk" class="mt-1 text-2xl font-bold text-slate-900">0</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
</section>

<section id="summary" class="py-16">
<div class="mx-auto max-w-7xl px-6">
  <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
    <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-teal-700">Total Assessments</p>
      <p id="totalAssessments" class="mt-3 text-4xl font-black text-slate-900">0</p>
      <p class="mt-2 text-sm text-slate-500">All stored reports in the system</p>
    </div>

    <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-700">Average BMI</p>
      <p id="averageBmi" class="mt-3 text-4xl font-black text-slate-900">0</p>
      <p class="mt-2 text-sm text-slate-500">Mean BMI across assessments</p>
    </div>

    <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-700">High Risk Cases</p>
      <p id="highRiskCases" class="mt-3 text-4xl font-black text-slate-900">0</p>
      <p class="mt-2 text-sm text-slate-500">Assessments flagged as high risk</p>
    </div>

    <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-700">Low Risk Cases</p>
      <p id="lowRiskCases" class="mt-3 text-4xl font-black text-slate-900">0</p>
      <p class="mt-2 text-sm text-slate-500">Assessments with lower concern levels</p>
    </div>
  </div>
</div>
</section>

<section id="charts" class="pb-16">
<div class="mx-auto max-w-7xl px-6">
  <div class="grid gap-6 xl:grid-cols-2">
    <div class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm">
      <h3 class="text-2xl font-black text-slate-900">Overall Risk Distribution</h3>
      <p class="mt-2 text-slate-600">Distribution of overall assessment risk levels across all saved reports.</p>
      <div class="mt-8 mx-auto max-w-[280px]">
        <canvas id="riskDistributionChart" height="240"></canvas>
      </div>
    </div>

    <div class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm">
      <h3 class="text-2xl font-black text-slate-900">Focus Nutrient Status Count</h3>
      <p class="mt-2 text-slate-600">Count of deficiency, borderline, adequate, and excess states for the main focus nutrients.</p>
      <div class="mt-8">
        <canvas id="focusStatusChart" height="140"></canvas>
      </div>
    </div>
  </div>

  <div class="mt-6 rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm">
    <h3 class="text-2xl font-black text-slate-900">Average Focus Nutrient Scores</h3>
    <p class="mt-2 text-slate-600">Average scores for iron, calcium, vitamin A, vitamin C, and protein across stored assessments.</p>
    <div class="mt-8">
      <canvas id="focusScoresAverageChart" height="120"></canvas>
    </div>
  </div>
</div>
</section>

<section class="pb-16">
<div class="mx-auto max-w-7xl px-6">
  <div class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm">
    <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-700">Recent Records</p>
        <h3 class="mt-2 text-3xl font-black text-slate-900">Latest assessments</h3>
      </div>
      <a href="/history" class="font-semibold text-emerald-700 transition hover:text-emerald-900">
        View full history
      </a>
    </div>

    <div class="mt-8 overflow-x-auto">
      <table class="min-w-full border-separate border-spacing-y-3">
        <thead>
          <tr class="text-left text-sm text-slate-500">
            <th class="px-4">Name</th>
            <th class="px-4">Date</th>
            <th class="px-4">BMI</th>
            <th class="px-4">Risk Level</th>
            <th class="px-4">Status</th>
            <th class="px-4">Action</th>
          </tr>
        </thead>
        <tbody>
          <% if (assessments && assessments.length) { %>
            <% assessments.slice(0, 8).forEach((assessment) => { %>
              <tr class="rounded-2xl bg-slate-50 text-sm text-slate-700">
                <td class="rounded-l-2xl px-4 py-4 font-semibold"><%= assessment.fullName || "Unnamed User" %></td>
                <td class="px-4 py-4"><%= assessment.createdAt ? new Date(assessment.createdAt).toLocaleDateString() : "N/A" %></td>
                <td class="px-4 py-4"><%= assessment.bmi || "N/A" %></td>
                <td class="px-4 py-4"><%= assessment.scoringSummary?.overall?.overallRiskLevel || "N/A" %></td>
                <td class="px-4 py-4"><%= assessment.scoringSummary?.overall?.overallStatus || "N/A" %></td>


  <td class="rounded-r-2xl px-4 py-4">
<div class="flex items-center gap-3">
<a
  href="/result/<%= assessment.id %>"
  class="font-semibold text-emerald-700 transition hover:text-emerald-900"
>
  View Result
</a>

<form
  action="/assessment/<%= assessment.id %>/delete"
  method="POST"
  class="inline"
  onsubmit="return confirm('Are you sure you want to delete this assessment?');"
>
  <button
    type="submit"
    class="font-semibold text-red-600 transition hover:text-red-800"
  >
    Delete
  </button>
</form>
</div>
</td>   


</div>
</td>
                
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="6" class="px-4 py-8 text-center text-slate-500">No assessments available yet.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
</section>

<%- include('partials/footer') %>

<script>
const assessments = <%- JSON.stringify(assessments || []) %>;

const totalAssessmentsValue = assessments.length;

const bmiValues = assessments
  .map((a) => Number(a.bmi))
  .filter((value) => Number.isFinite(value));

const averageBmiValue = bmiValues.length
  ? (bmiValues.reduce((sum, value) => sum + value, 0) / bmiValues.length).toFixed(2)
  : "0";

const overallRiskLevels = assessments.map(
  (a) => a.scoringSummary?.overall?.overallRiskLevel || "Unknown"
);

const highRiskCasesValue = overallRiskLevels.filter((risk) => risk === "High Risk").length;
const lowRiskCasesValue = overallRiskLevels.filter(
  (risk) => risk === "Low Risk" || risk === "Very Low Risk"
).length;

document.getElementById("totalAssessments").textContent = totalAssessmentsValue;
document.getElementById("averageBmi").textContent = averageBmiValue;
document.getElementById("highRiskCases").textContent = highRiskCasesValue;
document.getElementById("lowRiskCases").textContent = lowRiskCasesValue;

document.getElementById("snapshotTotalAssessments").textContent = totalAssessmentsValue;
document.getElementById("snapshotAverageBmi").textContent = averageBmiValue;
document.getElementById("snapshotHighRisk").textContent = highRiskCasesValue;
document.getElementById("snapshotLowRisk").textContent = lowRiskCasesValue;

const riskCounts = {
  "High Risk": 0,
  "Moderate Risk": 0,
  "Low Risk": 0,
  "Very Low Risk": 0,
  "Unknown": 0,
};

overallRiskLevels.forEach((risk) => {
  if (riskCounts[risk] !== undefined) {
    riskCounts[risk] += 1;
  } else {
    riskCounts["Unknown"] += 1;
  }
});

const focusStatusCounts = {
  Deficient: 0,
  Borderline: 0,
  Adequate: 0,
  Excess: 0,
};

const focusNutrientScoreTotals = {
  iron: [],
  calcium: [],
  vitaminA: [],
  vitaminC: [],
  protein: [],
};

assessments.forEach((assessment) => {
  const nutrients = assessment.nutrientResults || {};

  Object.entries(nutrients).forEach(([key, value]) => {
    if (value && value.focus) {
      if (focusStatusCounts[value.status] !== undefined) {
        focusStatusCounts[value.status] += 1;
      }

      if (focusNutrientScoreTotals[key] && Number.isFinite(Number(value.score))) {
        focusNutrientScoreTotals[key].push(Number(value.score));
      }
    }
  });
});

const focusScoreAverageLabels = ["Iron", "Calcium", "Vitamin A", "Vitamin C", "Protein"];
const focusScoreAverageData = [
  focusNutrientScoreTotals.iron,
  focusNutrientScoreTotals.calcium,
  focusNutrientScoreTotals.vitaminA,
  focusNutrientScoreTotals.vitaminC,
  focusNutrientScoreTotals.protein,
].map((scores) => {
  if (!scores.length) return 0;
  return Number((scores.reduce((sum, value) => sum + value, 0) / scores.length).toFixed(2));
});

function createDoughnutChart(id, labels, data) {
  const ctx = document.getElementById(id);
  if (!ctx) return;

  new Chart(ctx, {
    type: "doughnut",
    data: {
      labels,
      datasets: [
        {
          data,
        },
      ],
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: {
          position: "bottom",
        },
      },
    },
  });
}

function createBarChart(id, labels, data, label) {
  const ctx = document.getElementById(id);
  if (!ctx) return;

  new Chart(ctx, {
    type: "bar",
    data: {
      labels,
      datasets: [
        {
          label,
          data,
        },
      ],
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      scales: {
        y: {
          beginAtZero: true,
        },
      },
    },
  });
}

createDoughnutChart(
  "riskDistributionChart",
  Object.keys(riskCounts),
  Object.values(riskCounts)
);

createBarChart(
  "focusStatusChart",
  Object.keys(focusStatusCounts),
  Object.values(focusStatusCounts),
  "Focus Nutrient Status Count"
);

createBarChart(
  "focusScoresAverageChart",
  focusScoreAverageLabels,
  focusScoreAverageData,
  "Average Focus Nutrient Score"
);
</script>
</body>
</html>