<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title><%= title %></title>

<link rel="stylesheet" href="/css/output.css" />
<link rel="stylesheet" href="/css/polish.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>

<body class="bg-slate-50 text-slate-800" style="overflow-x:hidden">

<%- include('partials/navbar', { page: 'history', isAdmin: true }) %>

<section class="bg-gradient-to-br from-emerald-900 via-teal-800 to-slate-900 text-white">
  <div class="mx-auto max-w-7xl px-6 py-14">
    <div class="grid gap-8 md:grid-cols-[1.4fr_0.9fr] md:items-center">

      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-100">
          Stored Reports
        </p>

        <h2 class="mt-4 text-4xl font-black md:text-5xl">
          Assessment history and record management.
        </h2>

        <p class="mt-5 max-w-3xl text-base leading-8 text-slate-200">
          This page contains all saved assessment records. You can review generated reports,
          open full results, download PDFs, and remove unwanted records.
        </p>

        <div class="mt-8 flex flex-wrap gap-4">
          <a href="#history-table"
             class="rounded-2xl bg-emerald-500 px-6 py-3 font-semibold text-white transition hover:bg-emerald-400">
            View Records
          </a>

          <a href="/dashboard"
             class="rounded-2xl border border-white/20 bg-white/10 px-6 py-3 font-semibold text-white transition hover:bg-white/20">
            Back to Dashboard
          </a>
        </div>
      </div>

      <div class="rounded-[2rem] border border-white/10 bg-white/10 p-5 backdrop-blur-md">
        <div class="rounded-[1.5rem] bg-white p-6 text-slate-800 shadow-xl">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-teal-700">
            History Snapshot
          </p>

          <div class="mt-5 grid gap-4 sm:grid-cols-2">

            <div class="rounded-2xl bg-slate-50 p-4">
              <p class="text-sm text-slate-500">Stored Assessments</p>
              <p class="mt-1 text-2xl font-bold text-slate-900">
                <%= assessments && assessments.length ? assessments.length : 0 %>
              </p>
            </div>

            <div class="rounded-2xl bg-slate-50 p-4">
              <p class="text-sm text-slate-500">Latest Entry</p>
              <p class="mt-1 text-base font-bold text-slate-900">
                <%= (assessments && assessments.length && assessments[0].createdAt)
                  ? new Date(assessments[0].createdAt).toLocaleDateString()
                  : "N/A" %>
              </p>
            </div>

            <div class="rounded-2xl bg-slate-50 p-4 sm:col-span-2">
              <p class="text-sm text-slate-500">Management</p>
              <p class="mt-1 text-base font-bold text-slate-900">
                View, download, and delete saved records
              </p>
            </div>

          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<%
function statusClass(s) {
  if (!s) return 'adequate';

  var l = s.toLowerCase();

  if (l.includes('severe')) return 'severe';
  if (l.includes('high')) return 'severe';
  if (l.includes('moderate')) return 'moderate';
  if (l.includes('mild')) return 'mild';
  if (l.includes('low')) return 'adequate';
  if (l.includes('excess')) return 'excess';

  return 'adequate';
}
%>

<section id="history-table" class="py-16">
  <div class="mx-auto max-w-7xl px-6">

    <div class="rounded-[1.5rem] border border-slate-200 bg-white shadow-sm overflow-hidden">

      <div style="padding:20px 24px;border-bottom:1px solid #e2e8f0;display:flex;align-items:center;justify-content:space-between;">
        <div>
          <h3 style="font-size:16px;font-weight:700;color:#0f172a;">
            Assessment Records
          </h3>

          <p style="font-size:13px;color:#64748b;margin-top:2px;">
            <%= assessments && assessments.length ? assessments.length : 0 %>
            stored result<%= (assessments && assessments.length ? assessments.length : 0) !== 1 ? 's' : '' %>
          </p>
        </div>

        <a href="/"
           style="font-size:13px;font-weight:600;color:#059669;text-decoration:none;padding:8px 16px;background:#f0fdf4;border-radius:8px;border:1px solid #86efac;">
          + New Assessment
        </a>
      </div>

      <% if (!assessments || assessments.length === 0) { %>

      <div style="padding:48px 24px;text-align:center;color:#94a3b8;">
        <p style="font-size:28px;margin-bottom:8px;color:#cbd5e1;"><i class="fa-solid fa-inbox"></i></p>
        <p style="font-size:14px;font-weight:600;color:#64748b;">
          No assessments saved yet
        </p>
        <p style="font-size:13px;margin-top:4px;">
          <a href="/" style="color:#059669;">Start your first assessment →</a>
        </p>
      </div>

      <% } else { %>

      <div style="overflow-x:auto;">
        <table class="polished-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Name</th>
              <th>Age / Gender</th>
              <th>BMI</th>
              <th>Overall Status</th>
              <th>Risk Level</th>
              <th>Date</th>
              <th>Actions</th>
            </tr>
          </thead>

          <tbody>
            <% assessments.forEach(function(a, i) {
                 var sc = statusClass(
                   (a.scoringSummary &&
                    a.scoringSummary.overall &&
                    a.scoringSummary.overall.overallStatus)
                   ||
                   (a.scoringSummary &&
                    a.scoringSummary.overall &&
                    a.scoringSummary.overall.overallRiskLevel)
                 );
            %>

            <tr>
              <td style="color:#94a3b8;font-size:12px;"><%= i + 1 %></td>

              <td style="font-weight:600;">
                <%= a.fullName || 'Unknown' %>
              </td>

              <td style="color:#64748b;">
                <%= a.age %>y · <%= a.gender %>
              </td>

              <td>
                <span style="font-weight:700;"><%= a.bmi %></span>
                <span style="font-size:11px;color:#94a3b8;margin-left:4px;">
                  <%= a.bmiCategory %>
                </span>
              </td>

              <td>
                <span class="status-badge <%= sc %>">
                  <%= (a.scoringSummary &&
                      a.scoringSummary.overall &&
                      a.scoringSummary.overall.overallStatus)
                      || 'N/A' %>
                </span>
              </td>

              <td>
                <span class="status-badge <%= sc %>">
                  <%= (a.scoringSummary &&
                      a.scoringSummary.overall &&
                      a.scoringSummary.overall.overallRiskLevel)
                      || 'N/A' %>
                </span>
              </td>

              <td style="color:#64748b;font-size:12px;white-space:nowrap;">
                <%= a.createdAt ? new Date(a.createdAt).toLocaleDateString() : 'N/A' %>
              </td>

              <td>
                <div style="display:flex;gap:6px;flex-wrap:nowrap;">

                  <a href="/result/<%= a.id || a._id %>" class="tbl-btn tbl-btn-view">
                    View
                  </a>

                  <a href="/report/<%= a.id || a._id %>/pdf" class="tbl-btn tbl-btn-pdf">
                    PDF
                  </a>

                  <form action="/assessment/<%= a.id || a._id %>/delete"
                        method="POST"
                        style="margin:0;"
                        onsubmit="return confirm('Delete this record?');">

                    <button type="submit"
                            class="tbl-btn tbl-btn-delete"
                            style="border:none;cursor:pointer;">
                      Delete
                    </button>
                  </form>

                </div>
              </td>
            </tr>

            <% }); %>
          </tbody>
        </table>
      </div>

      <% } %>

    </div>
  </div>
</section>

<%- include('partials/footer') %>

</body>
</html>