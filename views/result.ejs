<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/output.css" />
  <link rel="stylesheet" href="/css/polish.css"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    .mini-chart-grid { grid-template-columns: repeat(5, 1fr); }
    @media (max-width: 1024px) { .mini-chart-grid { grid-template-columns: repeat(3, 1fr); } }
    @media (max-width: 640px)  { .mini-chart-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 420px)  { .mini-chart-grid { grid-template-columns: 1fr; } }
    @keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}
    @keyframes fadeIn{from{opacity:0}to{opacity:1}}
    .anim-fade-up{opacity:0}
    .anim-fade-up.visible{animation:fadeUp .5s ease forwards}
    .anim-fade-in{opacity:0}
    .anim-fade-in.visible{animation:fadeIn .5s ease forwards}
  </style>
</head>
<body class="bg-slate-50 text-slate-800" style="overflow-x:hidden">

  <%- include('partials/navbar', { page: '', isAdmin: typeof isAdmin !== 'undefined' ? isAdmin : false }) %>

  <!-- Hero Summary -->
  <section class="bg-gradient-to-br from-emerald-900 via-teal-800 to-slate-900 text-white">
    <div class="mx-auto max-w-7xl px-6 py-14">
      <div class="grid gap-8 md:grid-cols-[1.4fr_0.9fr] md:items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-100">Assessment Complete</p>
          <h2 class="mt-4 text-4xl font-black md:text-5xl">Your Nutritional Analysis result is ready.</h2>

          <% if (assessment.fullName) { %>
            <p class="mt-4 text-lg font-semibold text-emerald-100">
              Report for: <span class="text-white"><%= assessment.fullName %></span>
            </p>
          <% } %>

          <p class="mt-5 max-w-3xl text-base leading-8 text-slate-200">
            This report summarizes BMI, calorie adequacy, nutrient status, scoring, and recommendation-based guidance using the values entered in your assessment form.
          </p>

          <div class="mt-8 flex flex-wrap gap-4">
            <a href="#overview" class="rounded-2xl bg-emerald-500 px-6 py-3 font-semibold text-white transition hover:bg-emerald-400">
              View Overview
            </a>
            <a href="#graphs" class="rounded-2xl border border-white/20 bg-white/10 px-6 py-3 font-semibold text-white transition hover:bg-white/20">
              View Graphs
            </a>
            <a
              href="/report/<%= assessment.id %>/pdf"
              class="rounded-2xl border border-white/20 bg-white/10 px-6 py-3 font-semibold text-white transition hover:bg-white/20"
            >
              Download PDF Report
            </a>
          </div>
        </div>

        <div class="rounded-[2rem] border border-white/10 bg-white/10 p-5 backdrop-blur-md">
          <div class="rounded-[1.5rem] bg-white p-6 text-slate-800 shadow-xl">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-teal-700">Overall Summary</p>
            <div class="mt-5 space-y-4">
              <div class="rounded-2xl bg-slate-50 p-4">
                <p class="text-sm text-slate-500">Overall Status</p>
                <p class="mt-1 text-2xl font-bold text-slate-900"><%= assessment.scoringSummary?.overall?.overallStatus || "N/A" %></p>
              </div>
              <div class="rounded-2xl bg-slate-50 p-4">
                <p class="text-sm text-slate-500">Overall Risk Level</p>
                <p class="mt-1 text-2xl font-bold text-slate-900"><%= assessment.scoringSummary?.overall?.overallRiskLevel || "N/A" %></p>
              </div>
              <div class="grid gap-4 sm:grid-cols-2">
                <div class="rounded-2xl bg-slate-50 p-4">
                  <p class="text-sm text-slate-500">Average Score</p>
                  <p class="mt-1 text-xl font-bold text-slate-900"><%= assessment.scoringSummary?.overall?.averageScore ?? "N/A" %></p>
                </div>
                <div class="rounded-2xl bg-slate-50 p-4">
                  <p class="text-sm text-slate-500">Percentage Score</p>
                  <p class="mt-1 text-xl font-bold text-slate-900"><%= assessment.scoringSummary?.overall?.percentageScore ?? "N/A" %>%</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-10 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-3xl border border-white/10 bg-white/10 p-5">
          <p class="text-sm text-emerald-100">BMI</p>
          <p class="mt-2 text-3xl font-bold"><%= assessment.bmi %></p>
          <p class="mt-1 text-sm text-slate-200"><%= assessment.bmiCategory %></p>
        </div>

        <div class="rounded-3xl border border-white/10 bg-white/10 p-5">
          <p class="text-sm text-emerald-100">Recommended Calories</p>
          <p class="mt-2 text-3xl font-bold"><%= assessment.dailyCalories %></p>
          <p class="mt-1 text-sm text-slate-200">kcal/day</p>
        </div>

        <div class="rounded-3xl border border-white/10 bg-white/10 p-5">
          <p class="text-sm text-emerald-100">Current Intake</p>
          <p class="mt-2 text-3xl font-bold"><%= assessment.currentCalorieIntake %></p>
          <p class="mt-1 text-sm text-slate-200">kcal/day</p>
        </div>

        <div class="rounded-3xl border border-white/10 bg-white/10 p-5">
          <p class="text-sm text-emerald-100">Assessment Date</p>
          <p class="mt-2 text-xl font-bold">
            <%= assessment.createdAt ? new Date(assessment.createdAt).toLocaleDateString() : "N/A" %>
          </p>
          <p class="mt-1 text-sm text-slate-200">Saved result</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Overview Cards -->
  <section id="overview" class="py-16">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-teal-700">Deficient</p>
          <p class="mt-3 text-4xl font-black text-slate-900"><%= assessment.scoringSummary?.counts?.highRisk ?? 0 %></p>
          <p class="mt-2 text-sm text-slate-500">High risk nutrient results</p>
        </div>

        <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-700">Moderate Concern</p>
          <p class="mt-3 text-4xl font-black text-slate-900"><%= assessment.scoringSummary?.counts?.moderateRisk ?? 0 %></p>
          <p class="mt-2 text-sm text-slate-500">Borderline or excess findings</p>
        </div>

        <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-700">Adequate</p>
          <p class="mt-3 text-4xl font-black text-slate-900"><%= assessment.scoringSummary?.counts?.lowRisk ?? 0 %></p>
          <p class="mt-2 text-sm text-slate-500">Low risk nutrient results</p>
        </div>

        <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-700">Total Score</p>
          <p class="mt-3 text-4xl font-black text-slate-900"><%= assessment.scoringSummary?.overall?.totalScore ?? 0 %></p>
          <p class="mt-2 text-sm text-slate-500">Combined nutrient score</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BMI and Calorie Analysis  -->


  <%
const bmiCat = (assessment.bmiCategory || '').toLowerCase();
const bmiClass = bmiCat.includes('under') ? 'underweight'
               : bmiCat.includes('over')  ? 'overweight'
               : bmiCat.includes('obese') ? 'obese'
               : 'normal';
%>


<!-- ── BMI + Calorie Cards ───────────────────────────────── -->
<section class="pb-10">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid gap-6 lg:grid-cols-2 anim-fade-up">

      <!-- BMI Card -->
      <div class="bmi-card">
        <div class="bmi-card-header">
          <div class="bmi-card-icon"><i class="fa-solid fa-weight-scale"></i></div>
          <h3>Body Mass Index</h3>
        </div>
        <div style="display:flex;align-items:baseline;gap:0;">
          <span class="bmi-value <%= bmiClass %>"><%= assessment.bmi %></span>
          <span class="bmi-label <%= bmiClass %>"><%= assessment.bmiCategory %></span>
        </div>
        <div class="bmi-scale">
          <div class="bmi-scale-seg"></div>
          <div class="bmi-scale-seg"></div>
          <div class="bmi-scale-seg"></div>
          <div class="bmi-scale-seg"></div>
        </div>
        <p class="bmi-hint">Underweight (&lt;18.5) · Normal (18.5–24.9) · Overweight (25–29.9) · Obese (≥30)</p>
      </div>

      <!-- Calorie Card -->
      <div class="bmi-card">
        <div class="bmi-card-header">
          <div class="bmi-card-icon"><i class="fa-solid fa-fire"></i></div>
          <h3>Daily Calorie Comparison</h3>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;">
          <div style="background:#f8fafc;border-radius:10px;padding:12px;">
            <p style="font-size:11px;color:#64748b;margin-bottom:4px;">Estimated need</p>
            <p style="font-size:22px;font-weight:800;color:#0f172a;"><%= assessment.dailyCalories %> <span style="font-size:13px;font-weight:500;color:#64748b;">kcal</span></p>
          </div>
          <div style="background:#f8fafc;border-radius:10px;padding:12px;">
            <p style="font-size:11px;color:#64748b;margin-bottom:4px;">Your intake</p>
            <p style="font-size:22px;font-weight:800;color:#0f172a;"><%= assessment.currentCalorieIntake %> <span style="font-size:13px;font-weight:500;color:#64748b;">kcal</span></p>
          </div>
        </div>

        <% if (assessment.calorieComparison) {
             const dir = assessment.calorieComparison.direction || '';
             const diff = assessment.calorieComparison.difference;
             const isOver = dir.toLowerCase().includes('above') || dir.toLowerCase().includes('excess');
           %>
        <div style="background:<%= isOver ? '#fef2f2' : '#f0fdf4' %>;border-radius:10px;padding:10px 14px;display:flex;align-items:center;gap:8px;">
          <span style="font-size:16px;"><%= isOver ? '⬆️' : '⬇️' %></span>
          <span style="font-size:13px;font-weight:600;color:<%= isOver ? '#991b1b' : '#166534' %>;">
            <%= diff %> kcal <%= dir %> your estimated requirement
          </span>
        </div>
        <% } %>
      </div>

    </div>
  </div>
</section>



  <!-- Focus Nutrients -->
   <%
/*
  Helper: status mapping
*/
function statusClass(s) {
  if (!s) return 'adequate';
  const l = s.toLowerCase();
  if (l.includes('deficient'))  return 'severe';
  if (l.includes('borderline')) return 'moderate';
  if (l.includes('excess'))     return 'excess';
  return 'adequate';
}

function badgeLabel(s) {
  if (!s) return 'Adequate';
  const l = s.toLowerCase();
  if (l.includes('deficient'))  return 'Deficient';
  if (l.includes('borderline')) return 'Borderline';
  if (l.includes('excess'))     return 'Excess';
  return 'Adequate';
}
%>
<!-- ── Focus Nutrient Cards ──────────────────────────────── -->
<section class="pb-16">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-8">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-700">Focus Nutrients</p>
      <h3 class="mt-2 text-3xl font-black text-slate-900">Main nutrient findings</h3>
      <div style="display:flex;flex-wrap:wrap;gap:14px;margin-top:14px;">
        <span style="display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:600;color:#166534;"><span style="width:9px;height:9px;border-radius:50%;background:#22c55e;display:inline-block;"></span>Adequate</span>
        <span style="display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:600;color:#9a3412;"><span style="width:9px;height:9px;border-radius:50%;background:#f59e0b;display:inline-block;"></span>Borderline</span>
        <span style="display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:600;color:#991b1b;"><span style="width:9px;height:9px;border-radius:50%;background:#ef4444;display:inline-block;"></span>Deficient</span>
        <span style="display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:600;color:#5b21b6;"><span style="width:9px;height:9px;border-radius:50%;background:#8b5cf6;display:inline-block;"></span>Excess</span>
      </div>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4">
      <% Object.entries(assessment.nutrientResults || {}).forEach(([key, nutrient], idx) => { %>
        <% if (nutrient.focus) {
             const sc  = statusClass(nutrient.status || nutrient.riskLevel);
             const pct = Math.min(nutrient.percentageMet || 0, 100);
             const delay = Math.min(idx * 0.08, 0.4);
           %>
        <div class="nutrient-card anim-fade-up <%= sc %>" style="transition-delay:<%= delay %>s">

          <!-- header: name + badge -->
          <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:10px;margin-bottom:4px;">
            <h4 style="font-size:14px;font-weight:700;color:#0f172a;"><%= nutrient.nutrientName %></h4>
            <span class="status-badge <%= sc %>"><%= badgeLabel(nutrient.status || nutrient.riskLevel) %></span>
          </div>

          <!-- metrics row -->
          <div class="nc-metrics">
            <div class="nc-metric">
              <div class="nc-metric-label">Intake</div>
              <div class="nc-metric-value"><%= nutrient.intake %><span style="font-size:10px;font-weight:400;color:#64748b;margin-left:2px;"><%= nutrient.unit %></span></div>
            </div>
            <div class="nc-metric">
              <div class="nc-metric-label">RDA</div>
              <div class="nc-metric-value"><%= nutrient.referenceValue %><span style="font-size:10px;font-weight:400;color:#64748b;margin-left:2px;"><%= nutrient.unit %></span></div>
            </div>
            <div class="nc-metric">
              <div class="nc-metric-label">Coverage</div>
              <div class="nc-metric-value coloured <%= sc %>"><%= nutrient.percentageMet %>%</div>
            </div>
          </div>

          <!-- progress bar -->
          <div class="nc-progress-track">
            <div class="nc-progress-fill js-fill" data-fill="<%= pct %>" style="width:0%"></div>
          </div>
          <p style="font-size:10px;color:#94a3b8;margin-bottom:10px;"><%= pct %>% of daily requirement</p>

          <!-- footer: score + link -->
          <div style="display:flex;align-items:center;justify-content:space-between;margin-top:4px;">
            <a href="/nutrient/<%= assessment.id %>/<%= key %>"
               style="font-size:12px;font-weight:600;color:#059669;text-decoration:none;"
               onmouseover="this.style.color='#065f46'" onmouseout="this.style.color='#059669'">
              View details →
            </a>
            <span style="font-size:11px;color:#94a3b8;">Score: <%= nutrient.score ?? 'N/A' %><%= nutrient.score != null ? '/3' : '' %></span>
          </div>
        </div>
        <% } %>
      <% }) %>
    </div>
  </div>
</section>

<!-- ── All Nutrients (non-focus) ─────────────────────────── -->
<section class="pb-16 bg-slate-50/60">
  <div class="mx-auto max-w-7xl px-6 py-10">
    <div class="mb-8">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Supporting Nutrients</p>
      <h3 class="mt-2 text-2xl font-bold text-slate-900">Full nutrient breakdown</h3>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
      <% Object.entries(assessment.nutrientResults || {}).forEach(([key, nutrient]) => { %>
        <% if (!nutrient.focus) {
             const sc  = statusClass(nutrient.status || nutrient.riskLevel);
             const pct = Math.min(nutrient.percentageMet || 0, 100);
           %>
        <div class="nutrient-card <%= sc %>">
          <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:10px;margin-bottom:4px;">
            <h4 style="font-size:13px;font-weight:700;color:#0f172a;"><%= nutrient.nutrientName %></h4>
            <span class="status-badge <%= sc %>"><%= badgeLabel(nutrient.status || nutrient.riskLevel) %></span>
          </div>
          <div class="nc-metrics">
            <div class="nc-metric">
              <div class="nc-metric-label">Intake</div>
              <div class="nc-metric-value"><%= nutrient.intake %> <%= nutrient.unit %></div>
            </div>
            <div class="nc-metric">
              <div class="nc-metric-label">RDA</div>
              <div class="nc-metric-value"><%= nutrient.referenceValue %> <%= nutrient.unit %></div>
            </div>
            <div class="nc-metric">
              <div class="nc-metric-label">Coverage</div>
              <div class="nc-metric-value coloured <%= sc %>"><%= nutrient.percentageMet %>%</div>
            </div>
          </div>
          <div class="nc-progress-track">
            <div class="nc-progress-fill js-fill" data-fill="<%= pct %>" style="width:0%"></div>
          </div>
          <div style="display:flex;justify-content:flex-end;margin-top:6px;">
            <a href="/nutrient/<%= assessment.id %>/<%= key %>"
               style="font-size:12px;font-weight:600;color:#059669;text-decoration:none;">
              Details →
            </a>
          </div>
        </div>
        <% } %>
      <% }) %>
    </div>
  </div>
</section>

<section id="graphs" class="bg-white py-16">
  <div class="mx-auto max-w-7xl px-6">

    <div class="mb-8">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-teal-700">Graphical Analysis</p>
      <h3 class="mt-2 text-3xl font-black text-slate-900">Focus nutrient charts</h3>
      <p class="mt-2 text-slate-500 text-sm">Based on your 5 priority nutrients: Iron, Calcium, Vitamin A, Vitamin C, and Protein.</p>
    </div>

    <%
      const focusKeys   = Object.entries(assessment.nutrientResults || {}).filter(([,v]) => v.focus);
      const supportKeys = Object.entries(assessment.nutrientResults || {}).filter(([,v]) => !v.focus);

      function statusClass(s) {
        if (!s) return 'adequate';
        const l = s.toLowerCase();
        if (l.includes('deficient') || l.includes('high')) return 'severe';
        if (l.includes('borderline') || l.includes('moderate')) return 'moderate';
        if (l.includes('excess')) return 'excess';
        return 'adequate';
      }
      function statusColor(s) {
        const m = { severe:'#ef4444', moderate:'#f59e0b', excess:'#8b5cf6', adequate:'#22c55e' };
        return m[statusClass(s)] || '#22c55e';
      }
      function statusBg(s) {
        const m = { severe:'#fee2e2', moderate:'#fef9c3', excess:'#ede9fe', adequate:'#dcfce7' };
        return m[statusClass(s)] || '#dcfce7';
      }
      function statusText(s) {
        const m = { severe:'#991b1b', moderate:'#92400e', excess:'#5b21b6', adequate:'#166534' };
        return m[statusClass(s)] || '#166534';
      }
    %>

    <%# ── 1. Coverage bars ──────────────────────────────────────────────── %>
    <div class="mb-6 rounded-2xl border border-slate-200 bg-slate-50 p-6">
      <div class="mb-4 flex items-center gap-2">
        <i class="fa-solid fa-bars-progress text-teal-700 text-sm"></i>
        <h4 class="font-bold text-slate-900 text-sm">Focus nutrient coverage</h4>
        <span class="ml-auto text-xs text-slate-400">% of recommended daily intake</span>
      </div>
      <div class="space-y-3">
        <% focusKeys.forEach(([key, n]) => {
             const pct = Math.min(n.percentageMet || 0, 120);
             const displayPct = n.percentageMet || 0;
             const col = statusColor(n.status);
             const bg  = statusBg(n.status);
             const tc  = statusText(n.status);
           %>
        <div class="flex items-center gap-3">
          <span class="w-20 flex-shrink-0 text-xs font-semibold text-slate-700"><%= n.nutrientName %></span>
          <div class="relative flex-1 h-2.5 rounded-full bg-slate-200 overflow-hidden">
            <div class="h-full rounded-full transition-all js-fill" data-fill="<%= Math.min(pct/120*100,100) %>" style="width:0%;background:<%= col %>"></div>
          </div>
          <span class="w-10 flex-shrink-0 text-right text-xs font-bold" style="color:<%= col %>"><%= displayPct %>%</span>
          <span class="rounded-full px-2 py-0.5 text-[10px] font-semibold flex-shrink-0" style="background:<%= bg %>;color:<%= tc %>"><%= n.status %></span>
        </div>
        <% }) %>
      </div>
    </div>

    <%# ── 2. Summary charts row ──────────────────────────────────────────── %>
    <div class="mb-6 grid gap-5 lg:grid-cols-2">

      <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
        <div class="mb-3 flex items-center gap-2">
          <i class="fa-solid fa-circle-half-stroke text-teal-700 text-sm"></i>
          <h4 class="font-bold text-slate-900 text-sm">Status distribution</h4>
          <span class="ml-auto text-xs text-slate-400">All tracked nutrients</span>
        </div>
        <div style="height:180px;position:relative;">
          <canvas id="statusDistributionChart"></canvas>
        </div>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
        <div class="mb-3 flex items-center gap-2">
          <i class="fa-solid fa-chart-bar text-teal-700 text-sm"></i>
          <h4 class="font-bold text-slate-900 text-sm">Intake vs RDA</h4>
          <span class="ml-auto text-xs text-slate-400">Focus nutrients</span>
        </div>
        <div style="height:180px;position:relative;">
          <canvas id="intakeVsRdaChart"></canvas>
        </div>
      </div>

    </div>

    <%# ── 3. Individual mini charts ─────────────────────────────────────── %>
    <div class="mb-2">
      <div class="mb-4 flex items-center gap-2">
        <i class="fa-solid fa-microscope text-teal-700 text-sm"></i>
        <h4 class="font-bold text-slate-900 text-sm">Individual nutrient breakdown</h4>
      </div>
      <div class="grid gap-4 mini-chart-grid">
        <% focusKeys.forEach(([key, n]) => {
             const col = statusColor(n.status);
             const bg  = statusBg(n.status);
             const tc  = statusText(n.status);
           %>
        <div class="rounded-2xl border bg-white p-4" style="border-color:<%= bg %>">
          <div class="mb-1 flex items-center justify-between gap-1">
            <span class="text-xs font-bold text-slate-800"><%= n.nutrientName %></span>
          </div>
          <p class="text-[10px] text-slate-400 mb-2"><%= n.intake %> / <%= n.referenceValue %> <%= n.unit %></p>
          <div style="height:70px;position:relative;">
            <canvas id="mini_<%= key %>"></canvas>
          </div>
          <p class="mt-2 text-center text-[10px] font-bold" style="color:<%= tc %>"><%= n.percentageMet %>% of RDA</p>
        </div>
        <% }) %>
      </div>
    </div>

  </div>
</section>

  <!-- Recommendations -->
 <%
 /*
  REPLACEMENT for the Recommendations sections in result.ejs
  Uses:
    assessment.recommendationSummary.priorityRecommendations   — array
    assessment.recommendationSummary.supportingRecommendations — array
    assessment.recommendationSummary.generalAdvice             — array of strings

  Each rec item shape: { nutrientName, status, recommendedFoods: [] }
*/ 

%>

<!-- ── Priority Recommendations ─────────────────────────── -->
<section class="py-16">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-8">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-red-600">Priority Action</p>
      <h3 class="mt-2 text-3xl font-black text-slate-900">Main nutrient guidance</h3>
      <p class="mt-2 text-slate-500">Nutrients flagged as priority concern based on your assessment.</p>
    </div>

    <% const priority = assessment.recommendationSummary?.priorityRecommendations || []; %>
    <% if (priority.length) { %>
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      <% priority.forEach((item) => {
           const sc = statusClass(item.status);
         %>
      <div class="rec-card">
        <div class="rec-card-header">
          <div>
            <h4 class="rec-card-title"><%= item.nutrientName %></h4>
            <span class="status-badge <%= sc %>" style="margin-top:5px;display:inline-flex;"><%= item.status %></span>
          </div>
        </div>

        <% if (item.recommendations && item.recommendations.length) { %>
          <ul style="margin:0 0 10px;padding:0;list-style:none;">
            <% item.recommendations.slice(0,2).forEach(r => { %>
            <li style="font-size:12px;color:#475569;padding:3px 0;padding-left:14px;position:relative;">
              <span style="position:absolute;left:0;color:#059669;">•</span><%= r %>
            </li>
            <% }) %>
          </ul>
        <% } %>

        <% if (item.recommendedFoods && item.recommendedFoods.length) { %>
        <p style="font-size:11px;font-weight:600;color:#64748b;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.06em;">Good food sources</p>
        <div class="rec-food-list">
          <% item.recommendedFoods.slice(0,5).forEach(food => { %>
            <span class="food-pill"><%= food %></span>
          <% }) %>
        </div>
        <% } %>
      </div>
      <% }) %>
    </div>
    <% } else { %>
    <div style="padding:20px;border-radius:12px;background:#f0fdf4;border:1px solid #86efac;color:#166534;font-size:14px;">
      <i class="fa-solid fa-circle-check" style="color:#16a34a;margin-right:6px;"></i>No major priority nutrient concern flagged in this result.
    </div>
    <% } %>
  </div>
</section>

<!-- ── Supporting Recommendations ───────────────────────── -->
<section class="pb-16 bg-slate-50/60">
  <div class="mx-auto max-w-7xl px-6 py-10">
    <div class="mb-8">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-600">Supporting Guidance</p>
      <h3 class="mt-2 text-2xl font-bold text-slate-900">Additional nutrient guidance</h3>
    </div>

    <% const supporting = assessment.recommendationSummary?.supportingRecommendations || []; %>
    <% if (supporting.length) { %>
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      <% supporting.forEach((item) => {
           const sc = statusClass(item.status);
         %>
      <div class="rec-card">
        <div class="rec-card-header">
          <div>
            <h4 class="rec-card-title"><%= item.nutrientName %></h4>
            <span class="status-badge <%= sc %>" style="margin-top:5px;display:inline-flex;"><%= item.status %></span>
          </div>
        </div>
        <% if (item.recommendedFoods && item.recommendedFoods.length) { %>
        <div class="rec-food-list">
          <% item.recommendedFoods.slice(0,5).forEach(food => { %>
            <span class="food-pill"><%= food %></span>
          <% }) %>
        </div>
        <% } %>
      </div>
      <% }) %>
    </div>
    <% } else { %>
    <div style="padding:20px;border-radius:12px;background:#f8fafc;border:1px solid #e2e8f0;color:#64748b;font-size:14px;">
      No supporting nutrient issues require extra guidance at this time.
    </div>
    <% } %>

    <!-- General Advice -->
    <% const general = assessment.recommendationSummary?.generalAdvice || []; %>
    <% if (general.length) { %>
    <div style="margin-top:28px;">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500 mb-4">General Advice</p>
      <div style="display:grid;gap:10px;">
        <% general.forEach(advice => { %>
        <div style="display:flex;gap:12px;align-items:flex-start;background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:14px 16px;">
          <i class="fa-solid fa-lightbulb" style="color:#059669;font-size:16px;flex-shrink:0;margin-top:1px;"></i>
          <p style="font-size:13px;color:#334155;line-height:1.6;margin:0;"><%= advice %></p>
        </div>
        <% }) %>
      </div>
    </div>
    <% } %>
  </div>
</section>


  <%- include('partials/footer') %>

  <script>
  // Hand the server-rendered assessment data to the external chart
  // script via window globals — an external .js file can't use EJS
  // interpolation directly, so this small inline bridge is required.
  window.__NUTRIENT_RESULTS__ = <%- JSON.stringify(assessment.nutrientResults || {}) %>;
  window.__SCORING_SUMMARY__  = <%- JSON.stringify(assessment.scoringSummary  || {}) %>;
</script>
<script src="/js/charts.js" defer></script>
<script src="/js/animations.js" defer></script>
</body>
</html>