<%
/*
  This replaces the <form> content inside the Assessment Form section in index.ejs.
  The outer <form action="/analyze" method="POST"> wrapper stays the same —
  just replace everything inside it with this.

  Changes vs original:
  - Inputs use class="form-input" for the focus ring / hover polish
  - Fields are grouped inside .form-section cards with an icon + title
  - Nutrient inputs show a unit label inline (no layout change needed)
  - Submit button upgraded with icon + loading state
*/
%>

      <!-- ── Personal Information ─────────────────────────── -->
      <div class="form-section">
        <div class="form-section-title">
          <div class="section-icon">👤</div>
          Personal Information
        </div>
        <p>Used for BMI calculation and calorie estimation.</p>

        <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">

          <div>
            <label for="fullName" class="mb-2 block text-sm font-semibold text-slate-700">Full Name</label>
            <input id="fullName" type="text" name="fullName"
              value="<%= oldInput?.fullName || '' %>"
              placeholder="e.g. Amara Okafor"
              class="form-input" required>
          </div>

          <div>
            <label for="age" class="mb-2 block text-sm font-semibold text-slate-700">Age</label>
            <input id="age" type="number" name="age"
              value="<%= oldInput?.age || '' %>"
              placeholder="e.g. 25" min="1" max="120"
              class="form-input" required>
          </div>

          <div>
            <label for="gender" class="mb-2 block text-sm font-semibold text-slate-700">Gender</label>
            <select id="gender" name="gender" class="form-input" required>
              <option value="">Select Gender</option>
              <option value="male"   <%= oldInput?.gender === 'male'   ? 'selected' : '' %>>Male</option>
              <option value="female" <%= oldInput?.gender === 'female' ? 'selected' : '' %>>Female</option>
            </select>
          </div>

          <div>
            <label for="weight" class="mb-2 block text-sm font-semibold text-slate-700">Weight <span class="text-slate-400 font-normal">(kg)</span></label>
            <input id="weight" type="number" step="0.1" name="weight"
              value="<%= oldInput?.weight || '' %>"
              placeholder="e.g. 70"
              class="form-input" required>
          </div>

          <div>
            <label for="height" class="mb-2 block text-sm font-semibold text-slate-700">Height <span class="text-slate-400 font-normal">(cm)</span></label>
            <input id="height" type="number" step="0.1" name="height"
              value="<%= oldInput?.height || '' %>"
              placeholder="e.g. 170"
              class="form-input" required>
          </div>

          <div>
            <label for="activityLevel" class="mb-2 block text-sm font-semibold text-slate-700">Activity Level</label>
            <select id="activityLevel" name="activityLevel" class="form-input" required>
              <option value="">Select Activity Level</option>
              <option value="sedentary"         <%= oldInput?.activityLevel === 'sedentary'         ? 'selected' : '' %>>Sedentary</option>
              <option value="lightly_active"    <%= oldInput?.activityLevel === 'lightly_active'    ? 'selected' : '' %>>Lightly Active</option>
              <option value="moderately_active" <%= oldInput?.activityLevel === 'moderately_active' ? 'selected' : '' %>>Moderately Active</option>
              <option value="very_active"       <%= oldInput?.activityLevel === 'very_active'       ? 'selected' : '' %>>Very Active</option>
              <option value="extra_active"      <%= oldInput?.activityLevel === 'extra_active'      ? 'selected' : '' %>>Extra Active</option>
            </select>
          </div>

          <div class="md:col-span-2 xl:col-span-3">
            <label for="currentCalorieIntake" class="mb-2 block text-sm font-semibold text-slate-700">
              Current Daily Calorie Intake <span class="text-slate-400 font-normal">(kcal)</span>
            </label>
            <input id="currentCalorieIntake" type="number" step="0.1" name="currentCalorieIntake"
              value="<%= oldInput?.currentCalorieIntake || '' %>"
              placeholder="e.g. 1800"
              class="form-input" style="max-width:340px;" required>
          </div>
        </div>
      </div>

      <!-- ── Daily Nutrient Intake ──────────────────────── -->
      <div class="form-section">
        <div class="form-section-title">
          <div class="section-icon">🥗</div>
          Daily Nutrient Intake
        </div>
        <p>Enter approximate daily intake values. Leave at 0 if you didn't consume any.</p>

        <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">

          <%
            const nutrients = [
              { id: 'calories',      label: 'Calories',      unit: 'kcal', step: '1',   placeholder: '2000' },
              { id: 'protein',       label: 'Protein',       unit: 'g',    step: '0.1', placeholder: '55'   },
              { id: 'iron',          label: 'Iron',          unit: 'mg',   step: '0.1', placeholder: '8'    },
              { id: 'calcium',       label: 'Calcium',       unit: 'mg',   step: '0.1', placeholder: '1000' },
              { id: 'vitaminA',      label: 'Vitamin A',     unit: 'µg',   step: '0.1', placeholder: '900'  },
              { id: 'vitaminC',      label: 'Vitamin C',     unit: 'mg',   step: '0.1', placeholder: '90'   },
              { id: 'magnesium',     label: 'Magnesium',     unit: 'mg',   step: '0.1', placeholder: '400'  },
              { id: 'zinc',          label: 'Zinc',          unit: 'mg',   step: '0.1', placeholder: '11'   },
              { id: 'fiber',         label: 'Fiber',         unit: 'g',    step: '0.1', placeholder: '38'   },
              { id: 'fat',           label: 'Fat',           unit: 'g',    step: '0.1', placeholder: '65'   },
              { id: 'carbohydrates', label: 'Carbohydrates', unit: 'g',    step: '0.1', placeholder: '130'  },
            ];
          %>

          <% nutrients.forEach(n => { %>
          <div>
            <label for="<%= n.id %>" class="mb-2 block text-sm font-semibold text-slate-700">
              <%= n.label %> <span class="text-slate-400 font-normal">(<%= n.unit %>)</span>
            </label>
            <div style="position:relative;">
              <input id="<%= n.id %>" type="number" step="<%= n.step %>" name="<%= n.id %>"
                value="<%= oldInput?.[n.id] || '' %>"
                placeholder="<%= n.placeholder %>"
                class="form-input"
                style="padding-right: 46px;"
              >
              <span style="position:absolute;right:14px;top:50%;transform:translateY(-50%);font-size:11px;color:#94a3b8;pointer-events:none;"><%= n.unit %></span>
            </div>
          </div>
          <% }) %>

        </div>
      </div>

      <!-- ── Submit ─────────────────────────────────────── -->
      <div style="display:flex;justify-content:flex-end;margin-top:8px;">
        <button type="submit" id="submit-btn"
          style="display:inline-flex;align-items:center;gap:8px;
                 background:#059669;color:#fff;font-weight:700;font-size:15px;
                 padding:14px 32px;border-radius:14px;border:none;cursor:pointer;
                 box-shadow:0 4px 16px rgba(5,150,105,0.25);
                 transition:background 0.15s,transform 0.15s,box-shadow 0.15s;"
          onmouseover="this.style.background='#047857';this.style.transform='translateY(-1px)'"
          onmouseout="this.style.background='#059669';this.style.transform=''"
          onclick="this.textContent='Analysing…';this.disabled=true;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          Analyse Deficiencies
        </button>
      </div>
